# ==============================================================================
# Apache Spark Streaming Application Image
# ==============================================================================
# Base:    apache/spark:3.5.0
# Adds:    Python3, pip, requests library, PySpark environment config
# ==============================================================================

FROM apache/spark:3.5.0

USER root

# ==============================================================================
# Install Python dependencies
# ==============================================================================
# requests: Used by stream_processor.py to write to ClickHouse HTTP API
# (urllib is stdlib but requests gives cleaner error handling if needed later)
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
    python3-pip \
    curl \
    netcat-openbsd && \
    pip3 install --no-cache-dir requests && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# ==============================================================================
# Spark environment
# ==============================================================================
# SPARK_HOME and PATH are already set in the base image but re-declared
# here for clarity and to ensure they survive any ENV layering.
ENV SPARK_HOME=/opt/spark
ENV PATH="/opt/spark/bin:/opt/spark/sbin:${PATH}"

# PySpark Python runtime - driver and executor must match to avoid
# serialization errors when shipping closures across the cluster.
ENV PYSPARK_PYTHON=python3
ENV PYSPARK_DRIVER_PYTHON=python3

# Increase default network timeout to handle slow jar downloads at startup
ENV SPARK_SUBMIT_OPTS="-Dnetworkaddress.cache.ttl=60"

# ==============================================================================
# Pre-fetch the ClickHouse shaded JAR into the image
# so spark-submit doesn't need --jars at runtime and avoids download delays.
# The jar is copied from the mounted spark_jobs volume path at build time.
# If the jar is not present, the COPY will fail fast and clearly.
# ==============================================================================
COPY spark_jobs/clickhouse-jdbc-0.6.4-shaded.jar /opt/spark/jars/

# Return to non-root spark user for security
USER spark